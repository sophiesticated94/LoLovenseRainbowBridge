<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoLovenseRainbowBridge QR"
        Width="620"
        Height="840"
        MinWidth="520"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock x:Name="CodeText"
                       Text="Waiting for Lovense QR..."
                       FontSize="28"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="StatusText"
                       Text="This window stays open until you close it manually."
                       FontSize="14"
                       Opacity="0.75"
                       TextAlignment="Center"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="QR image"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,18,0,4" />
            <Image x:Name="QrImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,16,0,16"
                   Height="420" />
            <TextBlock x:Name="JobStatusText"
                       Text="Jobs: N/A"
                       FontSize="14"
                       Margin="0,18,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Window>
