      "Rules": [
        {
          "Name": "death-starts-new-incarnation",
          "Kind": "StateTransition",
          "Enabled": true,
          "Trigger": "ActiveDeath",
          "StateSlot": "CurrentBase",
          "Layer": "State",
          "Operation": "StartIncarnation",
          "Expression": "Max(0, CurrentBase - DeathPenalty)"
        },
        {
          "Name": "base-from-performance-health-and-pressure-vibrate",
          "Kind": "BaseModifier",
          "Enabled": true,
          "TargetFunctions": "Vibrate",
          "Layer": "Base",
          "Operation": "Set",
          "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier"
        },
        {
          "Name": "base-from-performance-health-and-pressure-vibrate1",
          "Kind": "BaseModifier",
          "Enabled": true,
          "TargetFunctions": "Vibrate1",
          "Layer": "Base",
          "Operation": "Set",
          "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier * PositionLeftWeight"
        },
        {
          "Name": "base-from-performance-health-and-pressure-vibrate2",
          "Kind": "BaseModifier",
          "Enabled": true,
          "TargetFunctions": "Vibrate2",
          "Layer": "Base",
          "Operation": "Set",
          "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier * PositionRightWeight"
        },
        {
          "Name": "multikill-square-growth-vibrate",
          "Kind": "BaseModifier",
          "Enabled": true,
          "Trigger": "ActiveMultikill",
          "TargetFunctions": "Vibrate",
          "Layer": "Base",
          "Operation": "Add",
          "Expression": "MultikillCount^2 - (MultikillCount - 1)^2"
        },
        {
          "Name": "multikill-square-growth-vibrate1",
          "Kind": "BaseModifier",
          "Enabled": true,
          "Trigger": "ActiveMultikill",
          "TargetFunctions": "Vibrate1",
          "Layer": "Base",
          "Operation": "Add",
          "Expression": "(MultikillCount^2 - (MultikillCount - 1)^2) * PositionLeftWeight"
        },
        {
          "Name": "multikill-square-growth-vibrate2",
          "Kind": "BaseModifier",
          "Enabled": true,
          "Trigger": "ActiveMultikill",
          "TargetFunctions": "Vibrate2",
          "Layer": "Base",
          "Operation": "Add",
          "Expression": "(MultikillCount^2 - (MultikillCount - 1)^2) * PositionRightWeight"
        },
        {
          "Name": "multikill-square-growth-all",
          "Kind": "BaseModifier",
          "Enabled": true,
          "Trigger": "ActiveMultikill",
          "TargetFunctions": "All",
          "Layer": "Timed",
          "Operation": "Add",
          "Expression": "Min(4, MultikillCount)"
        },
        {
          "Name": "track-max-vibrate-base-this-incarnation",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "StateSlot": "MaxBaseThisIncarnation",
          "Layer": "State",
          "Operation": "TrackMax",
          "Expression": "FunctionBase_Vibrate"
        },
        {
          "Name": "derive-min-base-from-max-base",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "StateSlot": "MinBaseThisIncarnation",
          "Layer": "State",
          "Operation": "TrackMax",
          "Expression": "MaxBaseThisIncarnation * 0.5"
        },
        {
          "Name": "clamp-base-to-incarnation-floor-vibrate",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "TargetFunctions": "Vibrate",
          "Layer": "Base",
          "Operation": "ClampMin",
          "Expression": "MinBaseThisIncarnation"
        },
        {
          "Name": "clamp-base-to-incarnation-floor-vibrate1",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "TargetFunctions": "Vibrate1",
          "Layer": "Base",
          "Operation": "ClampMin",
