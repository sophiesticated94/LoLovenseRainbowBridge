{
  "League": {
    "BaseUrl": "https://127.0.0.1:2999"
  },
  "Lovense": {
    "ToyId": "",
    "Platform": "LoLovenseRainbowBridge",
    "Developer": {
      "Token": "",
      "UserId": "",
      "UserName": "",
      "UserToken": ""
    },
    "LocalApi": {
      "EnableGetToys": true,
      "TimeoutMs": 3000,
      "AllowSelfSignedCertificate": true,
      "HeaderPlatform": "LoL Lovense Bridge"
    },
    "CommandTimeSec": 2.0,
    "DryRun": true,
    "ConnectTimeoutMs": 10000,
    "CommandAckTimeoutMs": 5000,
    "Mapping": {
      "Mode": "SimpleVibrate",
      "EnableComboActions": true,
      "EnableEventBursts": true,
      "EnableDeathStop": true,
      "EnableStrokeActions": false,
      "EnableCapabilityFiltering": true,
      "EnableStereoVibration": true,
      "DefaultStopPrevious": true,
      "UnknownCapabilityMode": "SafeUniversal",
      "StereoMode": "Auto",
      "StereoFallback": "Max",
      "LogToyViability": true,
      "ForceSupportedFunctions": [],
      "MaxActionIntensity": 20,
      "PumpMax": 3,
      "DepthMax": 3,
      "StrokeMax": 100,
      "FunctionProfiles": [
        { "FunctionName": "Vibrate", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 1.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Vibrate1", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 1.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Vibrate2", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 1.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "All", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Rotate", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Oscillate", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Suction", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Thrusting", "Enabled": true, "MinOutput": 0, "MaxOutput": 20, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Pump", "Enabled": true, "MinOutput": 0, "MaxOutput": 3, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Depth", "Enabled": true, "MinOutput": 0, "MaxOutput": 3, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 },
        { "FunctionName": "Stroke", "Enabled": false, "MinOutput": 0, "MaxOutput": 100, "BaseWeight": 0.0, "TimedWeight": 1.0, "EffectWeight": 1.0, "Curve": "Linear", "Smoothing": 0.0 }
      ],
      "Rules": [
        {
          "Name": "death-starts-new-incarnation",
          "Kind": "StateTransition",
          "Enabled": true,
          "Trigger": "ActiveDeath",
          "TargetFunctions": [
            { "Layer": "State", "StateSlot": "CurrentBase", "Operation": "StartIncarnation", "Expression": "Max(0, CurrentBase - DeathPenalty)" }
          ]
        },
        {
          "Name": "base-from-performance-health-and-pressure",
          "Kind": "BaseModifier",
          "Enabled": true,
          "TargetFunctions": [
            { "FunctionName": "Vibrate", "Layer": "Base", "Operation": "Set", "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier" },
            { "FunctionName": "Vibrate1", "Layer": "Base", "Operation": "Set", "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier * PositionLeftWeight" },
            { "FunctionName": "Vibrate2", "Layer": "Base", "Operation": "Set", "Expression": "(PerformanceScore + TotalMultikillCount - DeathPenalty) * LiveHealthMultiplier * HealthPressureMultiplier * PositionRightWeight" }
          ]
        },
        {
          "Name": "multikill-square-growth",
          "Kind": "BaseModifier",
          "Enabled": true,
          "Trigger": "ActiveMultikill",
          "TargetFunctions": [
            { "FunctionName": "Vibrate", "Layer": "Base", "Operation": "Add", "Expression": "MultikillCount^2 - (MultikillCount - 1)^2" },
            { "FunctionName": "Vibrate1", "Layer": "Base", "Operation": "Add", "Expression": "(MultikillCount^2 - (MultikillCount - 1)^2) * PositionLeftWeight" },
            { "FunctionName": "Vibrate2", "Layer": "Base", "Operation": "Add", "Expression": "(MultikillCount^2 - (MultikillCount - 1)^2) * PositionRightWeight" },
            { "FunctionName": "All", "Layer": "Timed", "Operation": "Add", "Expression": "Min(4, MultikillCount)" }
          ]
        },
        {
          "Name": "track-max-vibrate-base-this-incarnation",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "TargetFunctions": [
            { "Layer": "State", "StateSlot": "MaxBaseThisIncarnation", "Operation": "TrackMax", "Expression": "FunctionBase_Vibrate" }
          ]
        },
        {
          "Name": "derive-min-base-from-max-base",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "TargetFunctions": [
            { "Layer": "State", "StateSlot": "MinBaseThisIncarnation", "Operation": "TrackMax", "Expression": "MaxBaseThisIncarnation * 0.5" }
          ]
        },
        {
          "Name": "clamp-base-to-incarnation-floor",
          "Kind": "ThresholdModifier",
          "Enabled": true,
          "TargetFunctions": [
            { "FunctionName": "Vibrate", "Layer": "Base", "Operation": "ClampMin", "Expression": "MinBaseThisIncarnation" },
            { "FunctionName": "Vibrate1", "Layer": "Base", "Operation": "ClampMin", "Expression": "MinBaseThisIncarnation * PositionLeftWeight" },
            { "FunctionName": "Vibrate2", "Layer": "Base", "Operation": "ClampMin", "Expression": "MinBaseThisIncarnation * PositionRightWeight" }
          ]
        },
        {
          "Name": "objective-wave-texture",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "ObjectiveWaveValue > 0",
          "TargetFunctions": [
            { "FunctionName": "All", "Layer": "Timed", "Operation": "Add", "Expression": "ObjectiveWaveValue" },
            { "FunctionName": "Rotate", "Layer": "Timed", "Operation": "Add", "Expression": "ObjectiveWaveValue * 0.75" }
          ]
        },
        {
          "Name": "teamfight-burst-texture",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "TeamfightBurstValue > 0",
          "TargetFunctions": [
            { "FunctionName": "Rotate", "Layer": "Timed", "Operation": "Add", "Expression": "TeamfightBurstValue * 2" },
            { "FunctionName": "All", "Layer": "Timed", "Operation": "Add", "Expression": "TeamfightBurstValue" }
          ]
        },
        {
          "Name": "ace-burst-texture",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "AceBurstValue > 0",
          "TargetFunctions": [
            { "FunctionName": "Thrusting", "Layer": "Timed", "Operation": "Add", "Expression": "AceBurstValue * 2" },
            { "FunctionName": "All", "Layer": "Timed", "Operation": "Add", "Expression": "AceBurstValue" }
          ]
        },
        {
          "Name": "heartbeat-near-death-effect",
          "Kind": "Effect",
          "Enabled": true,
          "Condition": "HealthPercent <= LowHealthHeartbeatThreshold",
          "TargetFunctions": [
            { "FunctionName": "Vibrate", "Layer": "Effect", "Operation": "Add", "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8)" },
            { "FunctionName": "Vibrate1", "Layer": "Effect", "Operation": "Add", "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * PositionLeftWeight" },
            { "FunctionName": "Vibrate2", "Layer": "Effect", "Operation": "Add", "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * PositionRightWeight" },
            { "FunctionName": "Oscillate", "Layer": "Effect", "Operation": "Add", "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * 3" }
          ]
        },
        {
          "Name": "laning-phase-texture",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "LaningTextureValue > 0",
          "TargetFunctions": [
            { "FunctionName": "Suction", "Layer": "Timed", "Operation": "Add", "Expression": "LaningTextureValue" },
            { "FunctionName": "Oscillate", "Layer": "Timed", "Operation": "Add", "Expression": "LaningTextureValue" }
          ]
        },
        {
          "Name": "jungle-tension-ramp",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "JungleTensionValue > 0",
          "TargetFunctions": [
            { "FunctionName": "Oscillate", "Layer": "Timed", "Operation": "Add", "Expression": "JungleTensionValue * 2" },
            { "FunctionName": "Suction", "Layer": "Timed", "Operation": "Add", "Expression": "JungleTensionValue" }
          ]
        }
      ]
    }
  },
  "Runtime": {
    "PollMs": 500,
    "ResendEveryMs": 1500,
    "UnavailableRetryMs": 10000
  },
  "Scoring": {
    "KillWeight": 4.0,
