        },
        {
          "Name": "laning-phase-texture-oscillate",
          "Kind": "TimedContribution",
          "Enabled": true,
          "Condition": "LaningTextureValue > 0",
          "TargetFunctions": "Oscillate",
          "Layer": "Timed",
          "Operation": "Add",
