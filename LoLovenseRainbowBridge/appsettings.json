        },
        {
          "Name": "heartbeat-near-death-effect-vibrate",
          "Kind": "Effect",
          "Enabled": true,
          "Condition": "HealthPercent <= LowHealthHeartbeatThreshold",
          "TargetFunctions": "Vibrate",
          "Layer": "Effect",
          "Operation": "Add",
          "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8)"
        },
        {
          "Name": "heartbeat-near-death-effect-vibrate1",
          "Kind": "Effect",
          "Enabled": true,
          "Condition": "HealthPercent <= LowHealthHeartbeatThreshold",
          "TargetFunctions": "Vibrate1",
          "Layer": "Effect",
          "Operation": "Add",
          "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * PositionLeftWeight"
        },
        {
          "Name": "heartbeat-near-death-effect-vibrate2",
          "Kind": "Effect",
          "Enabled": true,
          "Condition": "HealthPercent <= LowHealthHeartbeatThreshold",
          "TargetFunctions": "Vibrate2",
          "Layer": "Effect",
          "Operation": "Add",
          "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * PositionRightWeight"
        },
        {
