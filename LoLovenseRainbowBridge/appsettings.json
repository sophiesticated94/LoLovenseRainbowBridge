          "Enabled": true,
          "Condition": "HealthPercent <= LowHealthHeartbeatThreshold",
          "TargetFunctions": "Oscillate",
          "Layer": "Effect",
          "Operation": "Add",
          "Expression": "HeartbeatAmplitude * Pow(Max(0, Sin((LoopTimeSec / HeartbeatPulseCycleSec) * 2 * Pi)), 8) * 3"
        },
