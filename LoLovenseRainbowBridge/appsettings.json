    "BaseRecoveryFloor": 0.5,
    "BaseRecoveryTarget": 0.8
  },
  "Logging": {
    "BaseDirectory": "log",
    "SessionDirectoryFormat": "yyyy-MM-dd_HH-mm-ss",
    "TrackLogLevel": "Debug",
    "LogRawLeague": false,
